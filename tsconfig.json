{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "types": [],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "declaration": true,
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noEmit": true,
    // Required by tsup's declaration bundler, which still sets the now-deprecated
    // `baseUrl` option (TS6 deprecation, TS7 removal). Build-time only; it lets us
    // ship bundled, node16-resolvable declarations. See tsup.config.ts.
    "ignoreDeprecations": "6.0"
  },
  "include": ["src", "test"]
}
