{
  "name": "beguile",
  "version": "0.1.0",
  "description": "Parse, validate, and retry: coax schema-valid data out of an unreliable producer.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mr-martinsosa/beguile.git"
  },
  "bugs": {
    "url": "https://github.com/mr-martinsosa/beguile/issues"
  },
  "homepage": "https://github.com/mr-martinsosa/beguile#readme",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./zod": {
      "import": {
        "types": "./dist/zod.d.ts",
        "default": "./dist/zod.js"
      },
      "require": {
        "types": "./dist/zod.d.cts",
        "default": "./dist/zod.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "zod": ["./dist/zod.d.ts"]
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "parse",
    "validate",
    "retry",
    "schema",
    "zod",
    "json",
    "llm",
    "structured-output"
  ],
  "author": "Martin Sosa <mr.martinsosa@gmail.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "zod": ">=4"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "zod": "^4.4.3"
  }
}
